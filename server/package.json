{
  "name": "anialerto-api",
  "version": "1.0.0",
  "description": "AniAlerto Farm Management System API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "db:setup": "psql -d anialerto_db -f ../database/schema.sql",
    "db:seed": "psql -d anialerto_db -f ../database/seed_data.sql",
    "db:reset": "npm run db:setup && npm run db:seed"
  },
  "keywords": [
    "farm",
    "management",
    "sms",
    "agriculture"
  ],
  "author": "AniAlerto Team",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
